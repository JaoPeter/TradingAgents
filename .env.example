# LLM Providers (set the one you use)
OPENAI_API_KEY=
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=
XAI_API_KEY=
DEEPSEEK_API_KEY=
DASHSCOPE_API_KEY=
ZHIPU_API_KEY=
OPENROUTER_API_KEY=

# Crypto data/news vendors (all optional, configure as needed)
# CoinMarketCap: Market data and fundamentals
COINMARKETCAP_API_KEY=

# CryptoCompare: News and sentiment analysis
CRYPTOCOMPARE_API_KEY=

# X (Twitter): Social sentiment (requires developer API access)
X_API_KEY=

# Binance: Free OHLCV data for crypto (no API key required for public endpoints)
BINANCE_API_KEY=
BINANCE_API_SECRET=

# DefiLlama: DeFi metrics and TVL data (no API key required)

# Optional: override Ollama endpoint (Docker profile sets this to http://ollama:11434/v1)
OLLAMA_BASE_URL=http://localhost:11434/v1
